# .env.example — Refueler
# CC-08 · Session 16 · 9 June 2026
#
# Copy this file to .env.local for local development.
# NEVER commit .env.local or any file containing live secrets to GitHub.
# .env.local is in .gitignore — verify before first commit.
#
# Variable prefixes:
#   VITE_       — injected at build time by Vite / Cloudflare Pages (client-visible)
#   no prefix   — server-side only (Supabase edge function secrets, never client-visible)
#
# To set edge function secrets:
#   supabase secrets set ZEBEDEE_API_KEY=<value> --project-ref tihgvdokeofnjxjkenmm
#   supabase secrets set ZEBEDEE_WEBHOOK_SECRET=<value> --project-ref tihgvdokeofnjxjkenmm

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------

# Project URL — safe to expose (needed by client SDK)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Anon key — safe to expose (enforced by RLS). Used in client-side JS.
# In command-centre.html: injected via Cloudflare Pages env var at build time.
# Pattern: const SUPABASE_ANON_KEY = '__SUPABASE_ANON_KEY__'; replaced by CF Pages.
VITE_SUPABASE_ANON_KEY=eyJ...

# Service role key — NEVER expose client-side. Edge functions only.
# Set via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=<value>
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---------------------------------------------------------------------------
# Zebedee / BOLT11
# ---------------------------------------------------------------------------

# ZBD API key — edge function only. Never in client bundle.
ZEBEDEE_API_KEY=

# ZBD webhook signing secret — used by bolt11-webhook to verify x-zebedee-signature.
ZEBEDEE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Cloudflare
# ---------------------------------------------------------------------------

# Analytics Worker auth token — used by refueler-analytics worker.
ANALYTICS_WORKER_TOKEN=

# ---------------------------------------------------------------------------
# Email (Resend)
# ---------------------------------------------------------------------------

# Resend API key — Supabase SMTP provider. Configured via Supabase dashboard.
# Used for: noreply@refueler.io magic link delivery via send.refueler.io subdomain.
RESEND_API_KEY=re_...

# ---------------------------------------------------------------------------
# ippon / Minibits (future — NUT-18 track)
# ---------------------------------------------------------------------------

# ippon base URL — set when NUT-18 send is confirmed live in Minibits.
# IPPON_BASE_URL=https://mint.example.com

# ---------------------------------------------------------------------------
# Development flags
# ---------------------------------------------------------------------------

# Set to 'true' to skip ZBD API calls in local dev and return a mock invoice.
# Never set in production.
VITE_MOCK_PAYMENTS=false
